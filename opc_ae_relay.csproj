  <Target Name="CleanLogs" BeforeTargets="Build">
    <!-- 删除 $(TargetDir)logs 目录及其所有内容 -->
    <RemoveDir Directories="$(TargetDir)logs" />
  </Target>
  <Target Name="MoveLibsToSubFolder" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <MakeDir Directories="$(TargetDir)lib" />
    <!-- 1. 移动所有依赖 DLL -->
    <ItemGroup>
      <DllFiles Include="$(TargetDir)*.dll" Exclude="$(TargetDir)$(TargetFileName)" />
    </ItemGroup>
    <Move SourceFiles="@(DllFiles)" DestinationFolder="$(TargetDir)lib" ContinueOnError="true" />


    <!-- 2. 删除 XML 文档（运行时不需要，排除 application.xml） -->
    <!--
         <ItemGroup>
             <XmlFiles Include="$(TargetDir)*.xml" Exclude="$(TargetDir)application.xml"/>
         </ItemGroup>
         <Delete Files="@(XmlFiles)"/>
         -->
    <!-- 3. PDB 保留在 lib/（本地调试可用，分发时只打包 exe+config+xml+view+lib/dll） -->
    <!--
       <ItemGroup>
           <PdbFiles Include="$(TargetDir)*.pdb"/>
       </ItemGroup>
       <Move SourceFiles="@(PdbFiles)" DestinationFolder="$(TargetDir)lib" ContinueOnError="true"/>
       -->
    <!-- 2. 移动 XML 文档（排除 application.xml） -->
    <ItemGroup>
      <XmlFiles Include="$(TargetDir)*.xml" Exclude="$(TargetDir)application.xml" />
    </ItemGroup>
    <Move SourceFiles="@(XmlFiles)" DestinationFolder="$(TargetDir)lib" ContinueOnError="true" />
    <!-- 3. PDB 保留在 lib/（排除主程序 PDB，它必须和 exe 同目录才能调试） -->
    <ItemGroup>
      <PdbFiles Include="$(TargetDir)*.pdb" Exclude="$(TargetDir)$(TargetName).pdb" />
    </ItemGroup>
    <Move SourceFiles="@(PdbFiles)" DestinationFolder="$(TargetDir)lib" ContinueOnError="true" />
    <!-- 4. 移动 SqlClient 多语言资源文件夹 -->
    <ItemGroup>
      <SatelliteFolders Include="cs;de;es;fr;it;ja;ko;pl;pt-BR;ru;tr;zh-Hans;zh-Hant" />
    </ItemGroup>
    <Exec Command="xcopy /s /y /q &quot;$(TargetDir)%(SatelliteFolders.Identity)\&quot; &quot;$(TargetDir)lib\%(SatelliteFolders.Identity)\&quot;" ContinueOnError="true" Condition="Exists('$(TargetDir)%(SatelliteFolders.Identity)')" />
    <RemoveDir Directories="@(SatelliteFolders->'$(TargetDir)%(Identity)')" ContinueOnError="true" />
    <Message Text="Release 输出整理完成：DLL / XML / PDB / 资源文件 → lib/" Importance="high" />
  </Target>
